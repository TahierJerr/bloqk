// prisma/schema.prisma

generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    OWNER
    STAFF
}

enum AppointmentStatus {
    PENDING // awaiting confirmation
    CONFIRMED
    CANCELLED
    NO_SHOW
    COMPLETED
}

enum PaymentStatus {
    PENDING
    PAID
    REFUNDED
    FAILED
}

// ─── AUTH (better-auth generated — do not touch) ─────────────────────────────

model User {
    id            String   @id @default(cuid())
    name          String
    email         String   @unique
    emailVerified Boolean  @default(false)
    image         String?
    role          Role     @default(OWNER)
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    
    sessions Session[]
    accounts Account[]
    
    // App relations
    salon Salon?
    staff Staff?
    
    @@map("user")
}

model Session {
    id        String   @id @default(cuid())
    expiresAt DateTime
    token     String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    ipAddress String?
    userAgent String?
    
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    @@index([userId])
    @@map("session")
}

model Account {
    id                    String    @id @default(cuid())
    accountId             String
    providerId            String
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt
    
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    
    @@index([userId])
    @@map("account")
}

model Verification {
    id         String   @id @default(cuid())
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    
    @@index([identifier])
    @@map("verification")
}

// ─── SALON ───────────────────────────────────────────────────────────────────

model Salon {
    id        String   @id @default(cuid())
    name      String
    slug      String   @unique
    phone     String?
    email     String?
    address   String?
    city      String?
    timezone  String   @default("Europe/Amsterdam")
    currency  String   @default("EUR")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    ownerId String @unique
    owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    
    staff        Staff[]
    services     Service[]
    clients      Client[]
    appointments Appointment[]
}

// ─── STAFF ───────────────────────────────────────────────────────────────────

model Staff {
    id        String   @id @default(cuid())
    name      String
    email     String?
    phone     String?
    color     String   @default("#6366f1")
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    salonId String
    salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
    
    // fase 2 — staff login
    userId String? @unique
    user   User?   @relation(fields: [userId], references: [id])
    
    appointments Appointment[]
    schedules    Schedule[]
}

model Schedule {
    id        String  @id @default(cuid())
    dayOfWeek Int
    startTime String
    endTime   String
    active    Boolean @default(true)
    
    staffId String
    staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

// ─── SERVICES ────────────────────────────────────────────────────────────────

model Service {
    id          String   @id @default(cuid())
    name        String
    description String?
    imageUrl    String?
    duration    Int
    price       Int
    active      Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    salonId String
    salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
    
    appointments Appointment[]
}

// ─── CLIENTS ─────────────────────────────────────────────────────────────────

model Client {
    id        String   @id @default(cuid())
    name      String
    email     String?
    phone     String?
    notes     String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    salonId String
    salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
    
    appointments Appointment[]
}

// ─── APPOINTMENTS ─────────────────────────────────────────────────────────────

model Appointment {
    id        String            @id @default(cuid())
    startTime DateTime
    endTime   DateTime
    status    AppointmentStatus @default(CONFIRMED)
    notes     String?
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt
    
    salonId String
    salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)
    
    staffId String
    staff   Staff  @relation(fields: [staffId], references: [id])
    
    serviceId String
    service   Service @relation(fields: [serviceId], references: [id])
    
    clientId String
    client   Client @relation(fields: [clientId], references: [id])
    
    payment Payment?
}

// ─── PAYMENTS ────────────────────────────────────────────────────────────────

model Payment {
    id        String        @id @default(cuid())
    amount    Int
    currency  String        @default("EUR")
    status    PaymentStatus @default(PENDING)
    mollieId  String?       @unique
    paidAt    DateTime?
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
    
    appointmentId String      @unique
    appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}