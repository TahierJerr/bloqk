// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (better-auth generated,  do not touch) ─────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  // App relations
  salon         Salon?
  staff         Staff?

  passkeys Passkey[]

  @@map("user")
  orders Order[]
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime?
  aaguid       String?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}


// ─── SALON ───────────────────────────────────────────────────────────────────

model Salon {
  id        String   @id @default(uuid())
  name      String
  slug      String?  @unique
  domain    String?  @unique
  phone     String?
  email     String?
  address   String?
  city      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId      String        @unique
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  staff        Staff[]
  services     Service[]
  appointments Appointment[]
}

// ─── STAFF ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  STAFF
}

model Staff {
  id           String        @id @default(uuid())
  name         String
  email        String?
  phone        String?
  imageUrl     String?
  color        String        @default("#6366f1")
  active       Boolean       @default(true)
  role         Role          @default(STAFF)

  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id])

  appointments Appointment[]
  schedules    Schedule[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Schedule {
  id        String  @id @default(uuid())
  dayOfWeek Int
  startTime String
  endTime   String
  active    Boolean @default(true)

  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, dayOfWeek])
}

// ─── SERVICES ────────────────────────────────────────────────────────────────

model Service {
  id           String        @id @default(uuid())
  name         String
  description  String?
  imageUrl     String?
  duration     Int
  price        Int
  active       Boolean       @default(true)

  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ─── APPOINTMENTS ─────────────────────────────────────────────────────────────

enum AppointmentStatus {
  PENDING // awaiting confirmation
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

model Appointment {
  id              String            @id @default(uuid())
  startTime       DateTime
  durationMinutes Int
  status          AppointmentStatus @default(CONFIRMED)
  notes           String?

  serviceName     String
  servicePrice    Int

  clientName      String
  clientEmail     String
  clientPhone     String?

  reminder24Sent  Boolean           @default(false)
  reminder2Sent   Boolean           @default(false)

  salonId         String
  salon           Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staffId         String?
  staff           Staff?            @relation(fields: [staffId], references: [id], onDelete: SetNull)
  serviceId       String?
  service         Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([salonId, startTime])
  @@index([staffId, startTime])
}

model Order {
  id        String      @id @default(uuid())
  salonName String
  salonType String
  address   String
  package   String
  status    OrderStatus @default(PENDING)

  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("order")
}

enum OrderStatus {
  PENDING
  PREVIEW_SENT
  APPROVED
  PAID
  ACTIVE
}