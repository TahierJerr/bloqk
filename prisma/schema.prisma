// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (better-auth generated,  do not touch) ─────────────────────────────

enum UserRole {
  USER
  SUPERADMIN
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  // App relations
  salon         Salon?
  staff         Staff?

  passkeys Passkey[]

  @@map("user")
  orders Order[]
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime?
  aaguid       String?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}


// ─── SALON ───────────────────────────────────────────────────────────────────

model Salon {
  id        String   @id @default(uuid())
  name      String
  slug      String?  @unique
  domain    String?  @unique
  phone     String?
  email     String?
  address   String?
  city      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId      String        @unique
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  staff        Staff[]
  services     Service[]
  appointments Appointment[]
  settings     SalonSettings?
  staffInvites StaffInvite[]
}

// ─── STAFF INVITES (uitnodigingslinks met token) ─────────────────────────────

model StaffInvite {
  id         String    @id @default(uuid())
  token      String    @unique
  email      String
  role       Role      @default(STAFF)
  expiresAt  DateTime
  acceptedAt DateTime?

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([salonId])
}

// ─── SALON SETTINGS (branding + openingstijden uit de intake-wizard) ─────────

model SalonSettings {
  id             String  @id @default(uuid())
  logoUrl        String?
  photoUrls      String[]
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  extraInfo      String?

  salonId String @unique
  salon   Salon  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  openingHours OpeningHours[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OpeningHours {
  id        String  @id @default(uuid())
  // 0 = maandag ... 6 = zondag
  dayOfWeek Int
  closed    Boolean @default(false)
  open      String?
  close     String?

  settingsId String
  settings   SalonSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, dayOfWeek])
}

// ─── STAFF ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  STAFF
}

model Staff {
  id           String        @id @default(uuid())
  name         String
  email        String?
  phone        String?
  imageUrl     String?
  color        String        @default("#6366f1")
  active       Boolean       @default(true)
  role         Role          @default(STAFF)

  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id])

  appointments Appointment[]
  schedules    Schedule[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Schedule {
  id        String  @id @default(uuid())
  dayOfWeek Int
  startTime String
  endTime   String
  active    Boolean @default(true)

  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, dayOfWeek])
}

// ─── SERVICES ────────────────────────────────────────────────────────────────

model Service {
  id           String        @id @default(uuid())
  name         String
  description  String?
  imageUrl     String?
  duration     Int
  price        Int
  active       Boolean       @default(true)

  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ─── APPOINTMENTS ─────────────────────────────────────────────────────────────

enum AppointmentStatus {
  PENDING // awaiting confirmation
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

model Appointment {
  id              String            @id @default(uuid())
  startTime       DateTime
  durationMinutes Int
  status          AppointmentStatus @default(CONFIRMED)
  notes           String?

  serviceName     String
  servicePrice    Int

  clientName      String
  clientEmail     String
  clientPhone     String?

  reminder24Sent  Boolean           @default(false)
  reminder2Sent   Boolean           @default(false)

  salonId         String
  salon           Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  staffId         String?
  staff           Staff?            @relation(fields: [staffId], references: [id], onDelete: SetNull)
  serviceId       String?
  service         Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([salonId, startTime])
  @@index([staffId, startTime])
}

model Order {
  id        String      @id @default(uuid())
  salonName String
  salonType String
  address   String
  package   String
  status    OrderStatus @default(PENDING)

  // Preview-URL die we delen zodra de pagina klaar is (status PREVIEW_SENT)
  previewUrl      String?
  // Laatste feedback wanneer de klant de preview niet goedkeurt
  feedbackReason  String?
  feedbackMessage String?
  // Mollie-betaling gekoppeld aan deze order
  molliePaymentId String? @unique

  // Intake: "wizard" (zelf invullen) of "call" (overleggen)
  intakeChoice      String?
  // Gewenste contactmethode bij "call": email | phone | video
  contactMethod     String?
  intakeCompletedAt DateTime?

  // Abonnementskeuze: monthly | yearly (verplicht voor dashboard + boekingen)
  billing           String?
  // Laatst bekende Mollie-betaalstatus (open/pending/authorized/paid/canceled/expired/failed)
  lastPaymentStatus String?
  // Mollie-klant waar de mandate en abonnementen aan hangen
  mollieCustomerId      String?
  // Abonnementen die na de eerste betaling zijn gestart
  mollieSubscriptionIds String[] @default([])

  // Herkomst van het domein: "existing" (eigen domein) | "suggestion" (gekozen suggestie)
  domainSource String?
  // Domeinbeheer na betaling: "managed" (Bloqk beheert) | "self" (klant beheert)
  dnsChoice    String?
  // Verhuiscode voor de domeinoverdracht naar ons TransIP-account
  eppCode      String?
  // Cloudflare-zone die we voor het domein hebben aangemaakt
  cloudflareZoneId    String?
  // Moment waarop de overdracht bij TransIP is aangevraagd
  transferRequestedAt DateTime?

  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("order")
}

enum OrderStatus {
  PENDING
  PREVIEW_SENT
  APPROVED
  PAID
  ACTIVE
  CANCELLED
}

// ─── PRICING (bewerkbaar via /admin/pricing, bedragen in centen) ─────────────

model PricingConfig {
  id String @id @default(uuid())

  // "Vanaf"-prijs voor het bouwen van de website (marketing)
  websiteBase       Int @default(14900)
  // Website gespreid betaald over 12 maanden (totaal)
  websiteSplitTotal Int @default(19900)
  // Website in één keer betaald (jaardeal)
  websiteUpfront    Int @default(17400)
  // Abonnement per maand
  subMonthly        Int @default(2900)
  // Abonnement per jaar (2 maanden gratis t.o.v. 12 × maandprijs)
  subYearly         Int @default(31300)
  // Informatieve uitsplitsing van het maandbedrag
  hostingShare      Int @default(900)
  softwareShare     Int @default(2000)

  updatedAt DateTime @updatedAt
}